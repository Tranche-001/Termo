{
  "permissions": {
    "allow": [
      "Bash(npx vite *)",
      "mcp__playwright",
      "Bash(npx eslint *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "node ./hooks/read_hook.js"
          }
        ]
      }
    ]
  },
  "enabledMcpjsonServers": [
    "playwright"
  ]
}
